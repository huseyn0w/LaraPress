# Laravel Dusk (browser / e2e) environment — copy to .env.dusk.local.
#
# Runs on the HOST against a DEDICATED database (cmstack_laravel_dusk) in the
# dockerised MySQL — it never touches the dev `cmstack_laravel` DB. The app under
# test is served on the host on :8000 with the dusk env; host Chrome drives it.
#
# DUSK=true makes tests/CreatesApplication.php skip its SQLite :memory: pin so
# the test process and the served app share this MySQL database.
#
# `make dusk` copies this file to .env.dusk.local if it is missing.

APP_NAME=Cmstack-Laravel
APP_ENV=dusk.local
APP_KEY=base64:hWz4XQ1e05OOCIj5INPyZYy8bnZ66bLqFw6JGBQor4E=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

DUSK=true

LOG_CHANNEL=stack

# Dedicated Dusk DB, reached from the host via the published MySQL port (33060).
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=33060
DB_DATABASE=cmstack_laravel_dusk
DB_USERNAME=cmstack_laravel
DB_PASSWORD=secret

# Deterministic reads: array cache + model-caching off (the long-running
# `artisan serve` process would otherwise serve stale cached rows across tests).
CACHE_DRIVER=array
MODEL_CACHE_ENABLED=false
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync

BROADCAST_DRIVER=log
FILESYSTEM_DISK=local
MAIL_MAILER=log

TEMPLATE_NAME=default
LOCALE=en
