# Testing environment — loaded automatically when APP_ENV=testing.
# Pins the test suite to an isolated in-memory SQLite database so tests NEVER
# touch the local MySQL / Docker dev database. Safe to commit (no secrets).
APP_ENV=testing
APP_KEY=base64:2fl+Ktvkfl+Fuz4Qp/A75G2RTiWVA/ZoKZvp6fiiM10=
APP_DEBUG=true

DB_CONNECTION=sqlite
DB_DATABASE=:memory:

BCRYPT_ROUNDS=4
CACHE_DRIVER=array
MAIL_MAILER=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array

CAPTCHA_ENABLED=false
