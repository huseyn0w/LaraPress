APP_NAME=LaraPress
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack

# Database (MySQL 8 is the documented default for local + Hostinger).
#   - Hostinger (production, no Docker): DB_HOST=localhost
#   - Local Docker Compose:              DB_HOST=mysql  (the compose service name)
# The same keys work in both environments; only DB_HOST differs.
# Tests use SQLite in-memory automatically (see phpunit.xml) - no DB setup needed.
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=larapress
# NOTE: the MySQL image forbids "root" as MYSQL_USER — use a dedicated app user.
DB_USERNAME=larapress
DB_PASSWORD=secret
# Used only by the local Docker MySQL service (docker-compose.yml); ignored on Hostinger.
DB_ROOT_PASSWORD=rootsecret

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

TEMPLATE_NAME=default

LOCALE=en

# Google reCAPTCHA (https://www.google.com/recaptcha/admin)
# Leave keys empty to disable captcha entirely (local/dev/test): forms render
# without a widget and captcha validation always passes.
# Set CAPTCHA_ENABLED=true and provide both keys to enforce it in production.
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
CAPTCHA_ENABLED=false

CONTACT_EMAIL=

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL=https://larapress.loc/login/facebook/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://larapress.loc/login/github/callback

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

